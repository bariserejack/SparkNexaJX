# Mobile app (current Expo setup still uses Supabase directly)
EXPO_PUBLIC_SUPABASE_URL=your_supabase_url
EXPO_PUBLIC_SUPABASE_ANON_KEY=your_supabase_anon_key
EXPO_PUBLIC_API_URL=http://localhost:4000

# Local infra (Docker)
DATABASE_URL=postgres://postgres:postgres@localhost:5432/sparknexa
MONGODB_URI=mongodb://root:root@localhost:27017
REDIS_URL=redis://localhost:6379

# OAuth provider configuration (used by Supabase or your backend)
#  - Supabase generally manages client IDs inside the dashboard but you can
#    store them here if you proxy or need them in code.
SUPABASE_GOOGLE_CLIENT_ID=your_google_client_id
SUPABASE_APPLE_CLIENT_ID=your_apple_client_id
SUPABASE_GITHUB_CLIENT_ID=your_github_client_id

# Phone verification (example using Twilio)
TWILIO_ACCOUNT_SID=your_twilio_account_sid
TWILIO_AUTH_TOKEN=your_twilio_auth_token
TWILIO_SERVICE_SID=your_twilio_verify_service_sid

# Backend service
API_PORT=4000
NODE_ENV=development
